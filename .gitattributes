# =========================
# Diff and Merge Settings
# =========================

# Use union merge for package files
package.json merge=union
package-lock.json merge=union
yarn.lock merge=union
requirements.txt merge=union

# Use binary for images to avoid merge conflicts
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary

# =========================
# Special Handling
# =========================

# Treat .git files as binary to avoid unwanted diffs
.git* binary

# Treat npm binaries as binary
bin/** binary
.bin/** binary

